    "NSCameraUsageDescription" : {
      "comment" : "Privacy - Camera Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use the camera to identify landmarks, buildings, and museum exhibits."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "カメラを使って名所、建築、博物館の展示を識別します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "카메라로 명소, 건축물, 박물관 전시를 인식합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用于拍照识别景点、建筑和展品。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用於拍照識別景點、建築和展品。"
          }
        }
      }
    },
    "NSLocationAlwaysAndWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location Always and When In Use Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use location to keep nearby narration and route suggestions updated during your visit."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "見学中に近くの解説とルート提案を更新するため位置情報を使用します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "관람 중 주변 해설과 경로 추천을 업데이트하기 위해 위치를 사용합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用于在游览中持续更新附近讲解和路线推荐。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用於在遊覽中持續更新附近講解和路線推薦。"
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location When In Use Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use your location to find nearby places and provide real-time guide narration."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現在地を使って近くの場所を探し、リアルタイム解説を提供します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "현재 위치로 주변 장소를 찾고 실시간 해설을 제공합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用于查找附近景点并提供实时讲解。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用於查找附近景點並提供即時講解。"
          }
        }
      }
    },
    "NSMicrophoneUsageDescription" : {
      "comment" : "Privacy - Microphone Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use the microphone so you can ask follow-up questions by voice."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "音声で追加質問するためマイクを使用します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "음성으로 후속 질문을 하기 위해 마이크를 사용합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用于语音追问和现场问答。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用於語音追問和現場問答。"
          }
        }
      }
    },
    "NSPhotoLibraryUsageDescription" : {
      "comment" : "Privacy - Photo Library Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose photos from your library to identify places, buildings, and exhibits."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "写真ライブラリから選んだ画像で場所、建築、展示を識別します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "사진 보관함의 이미지로 장소, 건축물, 전시를 인식합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用于从相册选择照片识别景点、建筑和展品。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用於從相簿選擇照片識別景點、建築和展品。"
          }
        }
      }
    },
    "NSSpeechRecognitionUsageDescription" : {
      "comment" : "Privacy - Speech Recognition Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use speech recognition to turn your spoken questions into text."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "話した質問をテキストに変換するため音声認識を使用します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "말한 질문을 텍스트로 바꾸기 위해 음성 인식을 사용합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用于将你的语音问题转成文字。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用於將你的語音問題轉成文字。"
          }
        }
      }
    }
  },
  "version" : "1.0"
}