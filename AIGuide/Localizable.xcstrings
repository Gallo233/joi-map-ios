    "audioGuide.taihedian.history.short" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The Hall of Supreme Harmony leads the outer court of the Forbidden City. Its terrace, roofline, and central axis all express the order and gravity of imperial ritual."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "太和殿は紫禁城外朝三大殿の中心です。台基、屋根、軸線の秩序が、皇帝儀礼の威厳を伝えています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "태화전은 자금성 외조 삼대전의 중심입니다. 기단, 지붕, 축선의 질서가 황권 의례의 장엄함을 보여줍니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "太和殿是紫禁城外朝三大殿之首，明清两代皇帝举行大典的地方。你现在看到的台基、屋顶和轴线秩序，都在传达皇权礼制的庄严。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "太和殿是紫禁城外朝三大殿之首，明清兩代皇帝舉行大典的地方。你現在看到的台基、屋頂和軸線秩序，都在傳達皇權禮制的莊嚴。"
          }
        }
      }
    },
