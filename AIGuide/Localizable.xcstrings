    "guide.findingNearbyPOIDesc" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "After location is ready, nearby attractions are matched first. If none are built in, the nearest museums, landmarks, or cultural places are suggested."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "位置取得後、まず近くの名所を照合します。内蔵データがない場合は近くの博物館、ランドマーク、文化施設を推薦します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "위치가 준비되면 주변 명소를 먼저 매칭합니다. 내장 명소가 없으면 가까운 박물관, 랜드마크, 문화 장소를 추천합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "定位完成后，会优先匹配附近景点；如果附近没有内置景点，会推荐最近的博物馆、地标或文化场所。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "定位完成後，會優先匹配附近景點；如果附近沒有內建景點，會推薦最近的博物館、地標或文化場所。"
          }
        }
      }
    },
