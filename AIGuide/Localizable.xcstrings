    "等定位完成、地图推荐返回，或先使用「识景」拍照识别。" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wait for location and map recommendations, or use Scan to identify by photo first."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "位置情報と地図候補を待つか、先に識別で写真認識してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "위치와 지도 추천을 기다리거나 먼저 인식에서 사진으로 식별하세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "等定位完成、地图推荐返回，或先使用“识景”拍照识别。"
          }
        },
        "zh-Hant" : {
