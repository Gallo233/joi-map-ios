    "sheet.correct.description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "On-site positioning combines GPS, route progress, and photo confirmation. Pick a better place manually to recalibrate this narration."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現地測位はGPS、ルート進行、写真確認を組み合わせます。より正確な場所を選ぶと案内を補正できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "현장 위치는 GPS, 경로 진행, 사진 확인을 함께 사용합니다. 더 정확한 장소를 선택하면 이번 해설을 바로 보정합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "现场定位会结合 GPS、路线进度和拍照识别。你可以手动选择更准确的点位，系统会立刻校准本次讲解。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現場定位會結合 GPS、路線進度和拍照識別。你可以手動選擇更準確的點位，系統會立刻校準本次講解。"
          }
        }
      }
    },
