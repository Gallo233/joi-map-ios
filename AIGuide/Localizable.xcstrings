    "legacy.place.arcCarrousel.note" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A small triumphal arch by the Louvre, good for photos and views toward the Tuileries Garden."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ルーヴル前の小さな凱旋門。写真やチュイルリー庭園方面の眺めに向いています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "루브르 앞의 작은 개선문으로 사진 촬영과 튈르리 정원 조망에 좋습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "卢浮宫前的小凯旋门，是拍照和远眺杜乐丽花园的好位置"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "羅浮宮前的小凱旋門，是拍照和遠眺杜樂麗花園的好位置"
          }
        }
      }
    },
    "legacy.place.louvre.name" : {
      "extractionState" : "stale",
