    "sheet.answer.sampleAnswer" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Official architectural sources place the Hall of Supreme Harmony at the core of the Forbidden City axis. It hosted state rituals, so its height, terrace levels, and roof form all signal imperial order."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "公式建築資料によると、太和殿は紫禁城の中軸線の中心に位置します。国家儀礼を担ったため、高さ、台基、屋根形式が皇帝の秩序を強く示しています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "공식 건축 자료에 따르면 태화전은 자금성 중축선의 핵심에 있습니다. 국가 의례를 담당했기 때문에 높이, 기단, 지붕 형식이 황권 질서를 강하게 드러냅니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "从官方建筑资料看，太和殿处在紫禁城中轴线的核心位置，是外朝三大殿中规格最高的空间。它承担大典、朝贺等国家礼仪，因此建筑高度、台基层级和屋顶形制都被设计成强烈的秩序象征。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "從官方建築資料看，太和殿處在紫禁城中軸線的核心位置，是外朝三大殿中規格最高的空間。它承擔大典、朝賀等國家禮儀，因此建築高度、台基層級和屋頂形制都被設計成強烈的秩序象徵。"
          }
        }
      }
    },
    "sheet.answer.sampleQuestion" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
