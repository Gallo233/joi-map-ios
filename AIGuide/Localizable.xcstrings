    "guide.localNarration.architecture.format" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When looking at %1$@, start with its position, proportions, structure, and details. %2$@"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@を見るときは、位置、比率、構造、細部から入ると理解しやすいです。%2$@"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@을 볼 때는 위치, 비례, 구조, 세부 문양을 먼저 보면 이해하기 쉽습니다. %2$@"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "看%1$@时，先抓住空间位置、结构比例和细节纹样。%2$@"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "看%1$@時，先抓住空間位置、結構比例和細節紋樣。%2$@"
          }
        }
      }
    },
    "guide.localNarration.casual.format" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Simply put, %1$@ is worth a pause because it connects this place’s past with the present. %2$@"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "簡単に言えば、%1$@はこの場所の過去と現在をつないでくれるので、立ち止まる価値があります。%2$@"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "쉽게 말해 %1$@은 이 공간의 과거와 현재를 이어주기 때문에 잠시 멈춰 볼 만합니다. %2$@"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "简单说，%1$@值得停下来，是因为它能把这片空间的历史和现在连起来。%2$@"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "簡單說，%1$@值得停下來，是因為它能把這片空間的歷史和現在連起來。%2$@"
          }
        }
      }
    },
    "guide.localNarration.children.format" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For kids, start by asking what shapes and colors they see in %1$@, then explain why it is here. %2$@"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "子どもには、%1$@の形や色を一緒に見てから、なぜここにあるのかを話すと伝わりやすいです。%2$@"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "어린이에게는 %1$@의 모양과 색을 먼저 물어본 뒤 왜 이곳에 있는지 설명하면 좋습니다. %2$@"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "给孩子讲%1$@，可以先问他们看到了什么形状和颜色，再讲它为什么被放在这里。%2$@"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "給孩子講%1$@，可以先問他們看到了什麼形狀和顏色，再講它為什麼被放在這裡。%2$@"
          }
        }
      }
    },
    "guide.localNarration.history.format" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The history of %1$@ is best read through its location, users, and why it has been preserved. %2$@"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@の歴史は、場所、使い手、今日まで残った理由から見ると分かりやすいです。%2$@"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@의 역사는 위치, 사용한 사람들, 지금까지 보존된 이유로 읽으면 좋습니다. %2$@"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@的历史可以从位置、使用者和保存至今的原因来看。%2$@"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@的歷史可以從位置、使用者和保存至今的原因來看。%2$@"
          }
        }
      }
    },
    "guide.localNarration.inDepth.format" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For a deeper reading of %1$@, connect historical function, spatial order, and the details in front of you. %2$@"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@を深く見るなら、歴史的機能、空間の秩序、目の前の細部を結びつけて考えるのが鍵です。%2$@"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@을 깊이 보려면 역사적 기능, 공간 질서, 현장의 세부 요소를 함께 이해하는 것이 핵심입니다. %2$@"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "深看%1$@，重点是把历史功能、空间秩序和现场细节放在一起理解。%2$@"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "深看%1$@，重點是把歷史功能、空間秩序和現場細節放在一起理解。%2$@"
          }
        }
      }
    },
    "guide.localNarration.legend.format" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can hear %1$@ as a story on site: not only a place, but a container for order, memory, and symbols. %2$@"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@は現地の物語として聞けます。場所であるだけでなく、秩序、記憶、象徴への想像を含んでいます。%2$@"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@은 현장의 이야기처럼 들을 수 있습니다. 장소일 뿐 아니라 질서, 기억, 상징을 담고 있습니다. %2$@"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@可以像一个现场故事来听：它不只是一个地点，也承载了人们对秩序、记忆和象征的想象。%2$@"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@可以像一個現場故事來聽：它不只是一個地點，也承載了人們對秩序、記憶和象徵的想像。%2$@"
          }
        }
      }
    },
    "guide.locating" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Locating"
          }
        },
