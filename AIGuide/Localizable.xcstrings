    "trip.spot.mainNotes" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Key focus: architecture, permanent displays, and representative works. Confirm opening hours and reservation rules first."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "主な見どころ：建築空間、常設展示、代表的な作品。先に開館時間と予約ルールを確認しましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "핵심 포인트: 건축 공간, 상설 전시, 대표 소장품. 운영 시간과 예약 규칙을 먼저 확인하세요."
