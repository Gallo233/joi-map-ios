    "legacy.place.louvreChina.note" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This is a same-name commercial complex, not the Louvre in Paris. Choose results with city and country for famous landmarks."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これは同名の商業施設で、パリのルーヴルではありません。有名スポットは都市と国付きの結果を選びましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "동명의 상업 시설이며 파리의 루브르가 아닙니다. 유명 명소는 도시와 국가가 표시된 결과를 선택하세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这是一处同名商业综合体，不是巴黎卢浮宫；建议搜索时选择带城市和国家的知名景点结果。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這是一處同名商業綜合體，不是巴黎羅浮宮；建議搜尋時選擇帶城市和國家的知名景點結果。"
          }
        }
      }
    },
    "legacy.place.louvreMuseum.name" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
