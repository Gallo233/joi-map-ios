    "guide.offlinePOI.asianArt.desc" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A major Asian art collection, ideal for stories by region, period, and craft."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "地域、時代、工芸を手がかりに語りやすいアジア美術の重要コレクションです。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "지역, 시대, 공예를 중심으로 설명하기 좋은 아시아 미술 컬렉션입니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "亚洲艺术收藏重镇，适合按地域、时代和工艺线索讲解。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "亞洲藝術收藏重鎮，適合按地域、時代和工藝線索講解。"
          }
        }
      }
    },
    "guide.offlinePOI.cableCar.desc" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A San Francisco transit heritage site, connecting engineering, hills, and city memory."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "坂、工学、都市の記憶を結びつけて語れるサンフランシスコの交通遺産です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "언덕, 공학, 도시 기억을 연결해 설명할 수 있는 샌프란시스코 교통 유산입니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "旧金山城市交通遗产，可结合街区坡度、工程和城市记忆讲解。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "舊金山城市交通遺產，可結合街區坡度、工程和城市記憶講解。"
          }
        }
      }
    },
    "guide.offlinePOI.cjm.desc" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A San Francisco museum known for adaptive architecture, identity, memory, and contemporary exhibitions."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "建築再生、アイデンティティ、記憶、現代展示で知られるサンフランシスコの博物館です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "건축 재생, 정체성, 기억, 현대 전시로 알려진 샌프란시스코의 박물관입니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "旧金山当代犹太博物馆，以建筑改造、身份记忆和当代展览著称。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "舊金山當代猶太博物館，以建築改造、身份記憶和當代展覽著稱。"
          }
        }
      }
    },
    "guide.offlinePOI.moad.desc" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A museum of the African diaspora, best framed through city, culture, and historical memory."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "都市、多文化、歴史記憶の視点で語りやすいアフリカン・ディアスポラ博物館です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "도시, 다문화, 역사적 기억의 관점으로 이야기하기 좋은 아프리카 디아스포라 박물관입니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "非洲离散文化博物馆，适合从城市、多元文化和历史记忆角度展开。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "非洲離散文化博物館，適合從城市、多元文化和歷史記憶角度展開。"
          }
        }
      }
    },
    "guide.offlinePOI.sfmoma.desc" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A modern and contemporary art museum suited to stories about architecture, curation, and public art."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "建築、キュレーション、公共芸術を軸に案内しやすい近現代美術館です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "건축, 큐레이션, 공공미술 이야기에 적합한 현대미술관입니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
