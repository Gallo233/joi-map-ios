        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "현재 버전은 위치 기반 해설을 중심으로 하고, 다른 두 방향은 진입점으로 남겨 점진적으로 통합합니다."
          }
        },
        "zh-Hans" : {
