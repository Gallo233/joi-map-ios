    "legacy.place.louvreMuseum.note" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Do not miss the Mona Lisa, Winged Victory, and Venus de Milo. A Denon-to-Sully route works well."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "モナ・リザ、サモトラケのニケ、ミロのヴィーナスは必見。ドゥノンからシュリーへ進むのがおすすめです。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모나리자, 사모트라케의 니케, 밀로의 비너스를 놓치지 마세요. 드농관에서 쉴리관으로 이동하는 동선이 좋습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "必看镇馆三宝：蒙娜丽莎、胜利女神、断臂维纳斯，建议按德农馆到叙利馆路线参观"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "必看鎮館三寶：蒙娜麗莎、勝利女神、斷臂維納斯，建議按德農館到敘利館路線參觀"
          }
        }
      }
    },
