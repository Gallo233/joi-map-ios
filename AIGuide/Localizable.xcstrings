    "guide.intro.seed.format" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You are viewing %@. I can answer its history, purpose, architectural highlights, kid-friendly explanations, or help plan your next stop."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ を見ています。歴史、用途、建築の見どころ、子ども向け説明、次の行き先について答えられます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@을 보고 있습니다. 역사, 용도, 건축 포인트, 아이용 설명, 다음 목적지 계획을 이어서 도와드릴 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你正在查看 %@。我可以继续回答它的历史、用途、建筑看点、亲子讲法，或者帮你规划下一站。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你正在查看 %@。我可以繼續回答它的歷史、用途、建築看點、親子講法，或者幫你規劃下一站。"
          }
        }
      }
    },
    "guide.localMode" : {
