    "sheet.source.description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI only reshapes sources into on-site narration. Low-confidence content is marked as uncertain instead of invented."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AIは資料を現地で聞きやすい案内に再構成します。不確かな内容は不確かと表示します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI는 자료를 현장에서 듣기 좋은 해설로 재구성합니다. 신뢰도가 낮은 내용은 불확실하다고 표시합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI 只负责把资料重组为适合现场收听的讲解；低置信度内容会提示“不确定”，不会装作知道。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI 只負責把資料重組為適合現場收聽的講解；低置信度內容會提示「不確定」，不會裝作知道。"
          }
        }
      }
    },
