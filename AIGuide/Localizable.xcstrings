    "legacy.place.met.note" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "From the Temple of Dendur to European paintings, pick 2-3 galleries for a focused visit."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "デンドゥール神殿から欧州絵画まで、興味に合わせて2〜3展示室を深く巡りましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "덴두르 신전부터 유럽 회화까지 관심사에 따라 2~3개 전시실을 깊게 둘러보세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "从埃及丹铎神殿到欧洲油画，建议按兴趣选择 2-3 个展厅深度游览"
          }
        },
        "zh-Hant" : {
